<Window x:Class="Пример_практика.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ДАРС-Склад - Адресное хранение" 
        WindowState="Maximized"
        FontSize="14"
        Background="#F0F2F5"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Стиль для кнопок навигации -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3A4F63"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0 5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15 0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2C3E50"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E2B38"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для активной кнопки -->
        <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#4A90E2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#357ABD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок операций -->
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для заголовков DataGrid -->
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#357ABD"/>
            <Setter Property="BorderThickness" Value="0 0 1 0"/>
        </Style>

        <!-- Стиль для ячеек DataGrid -->
        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0 0 1 0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для строк DataGrid -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F9FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для карточек статистики -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель навигации -->
        <Border Grid.Column="0" Background="#1E2B38" CornerRadius="0 20 20 0" Margin="0 0 5 0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Логотип -->
                    <Border Background="#4A90E2" CornerRadius="10" Padding="15" Margin="0 0 0 25">
                        <TextBlock Text="ДАРС-СКЛАД" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Border>

                    <!-- Основные разделы -->
                    <TextBlock Text="ОСНОВНЫЕ РАЗДЕЛЫ" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#7F8C8D" 
                               Margin="0 0 0 10"/>

                    <Button x:Name="BtnUsers" Content="👥 Пользователи" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnUsers_Click"
                            Tag="Users"/>

                    <Button x:Name="BtnProducts" Content="📦 Товары" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnProducts_Click"
                            Tag="Products"/>

                    <Button x:Name="BtnLocations" Content="📍 Ячейки хранения" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnLocations_Click"
                            Tag="Locations"/>

                    <Button x:Name="BtnInventory" Content="📊 Остатки" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnInventory_Click"
                            Tag="Inventory"/>

                    <Button x:Name="BtnTasks" Content="✅ Задания" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnTasks_Click"
                            Tag="Tasks"/>

                    <Button x:Name="BtnOperationsLog" Content="📋 Журнал операций" 
                            Style="{StaticResource NavButtonStyle}" 
                            Click="BtnOperationsLog_Click"
                            Tag="OperationsLog"/>

                    <Border Height="1" Background="#34495E" Margin="0 20"/>

                    <!-- Операции -->
                    <Border Background="#2C3E50" CornerRadius="8" Padding="10" Margin="0 0 0 10">
                        <StackPanel>
                            <TextBlock Text="ОПЕРАЦИИ С ДАННЫМИ" 
                                       FontSize="11" 
                                       FontWeight="Bold" 
                                       Foreground="#95A5A6" 
                                       Margin="0 0 0 8"
                                       HorizontalAlignment="Center"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BtnAdd" Grid.Column="0" 
                                        Content="➕" 
                                        Style="{StaticResource ActionButtonStyle}" 
                                        Background="#27AE60"
                                        Width="35"
                                        Margin="2"
                                        ToolTip="Добавить запись"
                                        Click="BtnAdd_Click"/>

                                <Button x:Name="BtnEdit" Grid.Column="1" 
                                        Content="✏️" 
                                        Style="{StaticResource ActionButtonStyle}" 
                                        Background="#2980B9"
                                        Width="35"
                                        Margin="2"
                                        ToolTip="Редактировать запись"
                                        Click="BtnEdit_Click"/>

                                <Button x:Name="BtnDelete" Grid.Column="2" 
                                        Content="🗑️" 
                                        Style="{StaticResource ActionButtonStyle}" 
                                        Background="#C0392B"
                                        Width="35"
                                        Margin="2"
                                        ToolTip="Удалить запись"
                                        Click="BtnDelete_Click"/>
                            </Grid>

                            <Grid Margin="0 5 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Добавить" 
                                           Foreground="#BDC3C7" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Изменить" 
                                           Foreground="#BDC3C7" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Удалить" 
                                           Foreground="#BDC3C7" FontSize="10" HorizontalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Информация о пользователе -->
                    <StackPanel Margin="0 10">
                        <TextBlock Text="Пользователь:" 
                                   Foreground="#7F8C8D" 
                                   FontSize="12"/>
                        <TextBlock x:Name="CurrentUserInfo" 
                                   Text="Оператор" 
                                   Foreground="White" 
                                   FontWeight="Bold" 
                                   FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Основная рабочая область -->
        <Border Grid.Column="1" Background="White" CornerRadius="20" Padding="20" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок и статистика -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 15">
                    <TextBlock x:Name="TitleText" 
                               Text="Пользователи" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"
                               Margin="0 0 20 0"/>

                    <Border Background="#E8F0FE" CornerRadius="15" Padding="8 3 8 3" VerticalAlignment="Center">
                        <TextBlock x:Name="CountText" 
                                   Text="Всего записей: 0" 
                                   Foreground="#4A90E2" 
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Карточки статистики (для некоторых разделов) -->
                <StackPanel x:Name="StatsPanel" Grid.Row="1" Orientation="Horizontal" Margin="0 0 0 20" Visibility="Collapsed">
                    <Border Style="{StaticResource StatCardStyle}" Width="200">
                        <StackPanel>
                            <TextBlock Text="Всего ячеек" Foreground="#7F8C8D" FontSize="12"/>
                            <TextBlock x:Name="TotalLocationsStat" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}" Width="200">
                        <StackPanel>
                            <TextBlock Text="Свободно" Foreground="#7F8C8D" FontSize="12"/>
                            <TextBlock x:Name="FreeLocationsStat" Text="0" FontSize="24" FontWeight="Bold" Foreground="#27AE60"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}" Width="200">
                        <StackPanel>
                            <TextBlock Text="Занято" Foreground="#7F8C8D" FontSize="12"/>
                            <TextBlock x:Name="OccupiedLocationsStat" Text="0" FontSize="24" FontWeight="Bold" Foreground="#C0392B"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Таблицы данных -->
                <Grid Grid.Row="2">
                    <!-- Таблица пользователей (Users) -->
                    <DataGrid x:Name="UsersGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Visible"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="150"/>
                            <DataGridTextColumn Header="Пароль" Binding="{Binding Password}" Width="150"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Таблица товаров (Products) -->
                    <DataGrid x:Name="ProductsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Collapsed"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="120"/>
                            <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="250"/>
                            <DataGridTextColumn Header="Штрих-код" Binding="{Binding Barcode}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Таблица ячеек хранения (Locations) -->
                    <DataGrid x:Name="LocationsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Collapsed"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                            <DataGridTextColumn Header="Ряд" Binding="{Binding Row}" Width="80"/>
                            <DataGridTextColumn Header="Стеллаж" Binding="{Binding Rack}" Width="80"/>
                            <DataGridTextColumn Header="Полка" Binding="{Binding Shelf}" Width="80"/>
                            <DataGridTextColumn Header="Полный код" Binding="{Binding FullCode}" Width="150"/>
                            <DataGridCheckBoxColumn Header="Занято" Binding="{Binding IsOccupied}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Таблица остатков (Inventory) - ИСПРАВЛЕНО -->
                    <DataGrid x:Name="InventoryGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Collapsed"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="200"/>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding ProductArticle}" Width="120"/>
                            <DataGridTextColumn Header="Ячейка" Binding="{Binding LocationCode}" Width="150"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Таблица заданий (Tasks) - ИСПРАВЛЕНО -->
                    <DataGrid x:Name="TasksGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Collapsed"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                            <DataGridTextColumn Header="Тип задания" Binding="{Binding TaskType}" Width="150"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn Header="Исполнитель" Binding="{Binding AssignedTo}" Width="150"/>
                            <DataGridTextColumn Header="Срок" Binding="{Binding DueDate}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Таблица журнала операций (OperationsLog) - ИСПРАВЛЕНО -->
                    <DataGrid x:Name="OperationsLogGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Visibility="Collapsed"
                              Background="White"
                              BorderBrush="#E0E0E0"
                              BorderThickness="1"
                              GridLinesVisibility="None"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              SelectionUnit="FullRow"
                              SelectionMode="Single"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                            <DataGridTextColumn Header="Дата операции" Binding="{Binding OperationDate}" Width="150"/>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding UserName}" Width="150"/>
                            <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="200"/>
                            <DataGridTextColumn Header="Детали" Binding="{Binding Details}" Width="300"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>